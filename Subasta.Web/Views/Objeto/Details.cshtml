@model Subasta.Aplication.DTOs.ObjetoDTO

@{
    ViewData["Title"] = "Detalle del Objeto";
}

<h2 class="fw-bold mb-4">@Model.Nombre</h2>

<div class="row mb-4">

    <!-- GALERÍA DE IMÁGENES -->
    <div class="col-md-4">

        @if (Model.Imagenes != null && Model.Imagenes.Any())
        {
            <div id="carouselImagenes" class="carousel slide shadow rounded" data-bs-ride="carousel">
                <div class="carousel-inner">

                    @for (int i = 0; i < Model.Imagenes.Count; i++)
                    {
                        var imagen = Model.Imagenes[i];

                        <div class="carousel-item @(i == 0 ? "active" : "")">
                            <div class="d-flex justify-content-center align-items-center"
                                 style="height: 400px;">

                                <img src="data:image/jpeg;base64,@Convert.ToBase64String(imagen)"
                                     style="max-height:100%; max-width:100%; object-fit:contain;"
                                     class="rounded shadow-sm"
                                     alt="Imagen @(i + 1)">
                            </div>
                        </div>
                    }

                </div>

                <button class="carousel-control-prev" type="button"
                        data-bs-target="#carouselImagenes"
                        data-bs-slide="prev">

                    <span class="d-flex justify-content-center align-items-center  bg-dark rounded-circle"
                          style="width:40px; height:40px;">
                        <span class="carousel-control-prev-icon "></span>
                    </span>

                </button>

                <button class="carousel-control-next" type="button"
                        data-bs-target="#carouselImagenes"
                        data-bs-slide="next">

                    <span class="d-flex justify-content-center align-items-center bg-dark rounded-circle"
                          style="width:40px; height:40px;">
                        <span class="carousel-control-next-icon"></span>
                    </span>

                </button>
            </div>
        }
        else
        {
            <div class="alert alert-secondary text-center">
                No hay imágenes disponibles para este objeto.
            </div>
        }

    </div>

    <div class="col-md-6">

        <div class="card shadow-sm">
            <div class="card-body">

                <dl class="row mb-0">

                    <dt class="col-sm-4">Descripción</dt>
                    <dd class="col-sm-8">@Model.Descripcion</dd>

                    <dt class="col-sm-4">Propietario</dt>
                    <dd class="col-sm-8 fw-semibold">@Model.Vendedor</dd>

                    <dt class="col-sm-4">Estado actual</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-info text-dark px-3 py-2">
                            @Model.Estado
                        </span>
                    </dd>

                    <dt class="col-sm-4">Condición</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-warning text-dark px-3 py-2">
                            @Model.Condicion
                        </span>
                    </dd>

                    <dt class="col-sm-4">Fecha registro</dt> 
                    <dd class="col-sm-8"> 
                        @Model.FechaRegistro.ToString("dd MMMM yyyy")
                    </dd>
                    <div class="d-flex align-items-center mb-3">
                        <div class="me-3">
                            <span class="fw-bold">Categorías</span>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            @if (Model.Categorias != null && Model.Categorias.Any())
                            {
                                foreach (var cat in Model.Categorias)
                                {
                                    <span class="badge border-1 border-info text-primary bg-light px-3 py-2 rounded-pill shadow-sm">@cat</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Sin categorías</span>
                            }
                        </div>
                    </div>

                </dl>

            </div>
        </div>

    </div>

</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">

        <h4 class="fw-bold mb-3">Historial de Subastas</h4>

        @if (Model.HistorialSubastas != null && Model.HistorialSubastas.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">

                    <thead class="table-dark">
                        <tr>
                            <th>ID Subasta</th>
                            <th>Fecha Inicio</th>
                            <th>Fecha Cierre</th>
                            <th class="text-center">Estado</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var sub in Model.HistorialSubastas)
                        {
                            <tr>
                                <td class="fw-semibold">@sub.IdSubasta</td>
                                <td>@sub.FechaHoraInicio.ToString("f")</td>
                                <td>@sub.FechaHoraCierre.ToString("f")</td>
                                <td class="text-center">
                                    <span class="badge bg-primary px-3 py-2">
                                        @sub.EstadoSubasta
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        }
        else
        {
            <div class="alert alert-light border">
                <p>No hay historial de subastas para este objeto.</p>
            </div>
        }

    </div>
</div>
<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-dark">
        <i class="bi bi-arrow-left me-1"></i>Volver al listado
    </a>
</div>