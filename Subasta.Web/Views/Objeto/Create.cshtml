@model Subasta.Aplication.DTOs.ObjetoDTO

@{
    ViewData["Title"] = "Crear objeto";
}

<div class="container py-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="d-flex align-items-center mb-4 border-bottom pb-3">
                <div class="bg-primary text-white rounded-circle p-3 me-3">
                    <i class="bi bi-box-seam fs-3"></i>
                </div>
                <div>
                    <h1 class="h3 mb-0 text-dark">Nuevo Objeto</h1>
                    <p class="text-muted mb-0">Complete los detalles para publicar en la subasta</p>
                </div>
            </div>

            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="row g-4">

                    <!-- IZQUIERDA -->
                    <div class="col-md-7">

                        <!-- Info sistema -->
                        <div class="card shadow-sm mb-4 border-0">
                            <div class="card-header bg-light fw-bold text-uppercase small text-muted">
                                <i class="bi bi-person-check me-1"></i> Información del sistema
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label class="form-label fw-semibold text-muted">Usuario vendedor</label>
                                    <input type="text"
                                           class="form-control bg-light"
                                           value="@(ViewBag.UsuarioActual ?? "Usuario Actual")"
                                           readonly />
                                </div>

                                <div class="mb-0">
                                    <label class="form-label fw-semibold text-muted">Estado inicial</label>
                                    <input type="text"
                                           class="form-control bg-light"
                                           value="@(ViewBag.Estado ?? "Activo")"
                                           readonly />
                                </div>
                            </div>
                        </div>

                        <!-- Info general -->
                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-transparent fw-bold text-uppercase small text-muted">
                                <i class="bi bi-info-circle me-1"></i> Información General
                            </div>
                            <div class="card-body px-4 py-3">
                                <div class="mb-3">
                                    <label asp-for="Nombre" class="form-label fw-semibold"></label>
                                    <input asp-for="Nombre" class="form-control" placeholder="Ej: Reloj de colección 1950" />
                                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Descripcion" class="form-label fw-semibold"></label>
                                    <textarea asp-for="Descripcion" class="form-control" rows="6" placeholder="Describa el estado, historia o detalles relevantes..."></textarea>
                                    <span asp-validation-for="Descripcion" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- DERECHA -->
                    <div class="col-md-5">

                        <!-- Clasificación -->
                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-transparent fw-bold text-uppercase small text-muted">
                                <i class="bi bi-tags me-1"></i> Clasificación
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Condición</label>
                                    <select asp-for="IdCondicion"
                                            class="form-select border-primary-subtle shadow-none"
                                            asp-items="@(new SelectList(ViewBag.ListCondicion,"IdCondicion","Descripcion"))">
                                        <option value="" disabled selected>Selecciona una condición</option>
                                    </select>
                                    <span asp-validation-for="IdCondicion" class="text-danger small"></span>
                                </div>

                                <div class="mb-0">
                                    <label class="form-label fw-semibold">Categorías</label>
                                    <select id="selectedCategorias"
                                            name="selectedCategorias"
                                            class="form-select"
                                            asp-items="ViewBag.ListCategorias"
                                            multiple>
                                    </select>

                                    @if (ViewData.ModelState["selectedCategorias"]?.Errors.Count > 0)
                                    {
                                        <span class="text-danger small d-block mt-1">
                                            @ViewData.ModelState["selectedCategorias"].Errors[0].ErrorMessage
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Multimedia -->
                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-transparent fw-bold text-uppercase small text-muted">
                                <i class="bi bi-camera me-1"></i> Multimedia
                            </div>
                            <div class="card-body text-center">
                                <label class="form-label fw-semibold d-block text-start">Imágenes del objeto</label>

                                <input type="file"
                                       id="imageFiles"
                                       name="imageFiles"
                                       class="form-control mb-3"
                                       accept="image/*"
                                       multiple />

                                @if (ViewData.ModelState["Imagenes"]?.Errors.Count > 0)
                                {
                                    <span class="text-danger small d-block mb-2">
                                        @ViewData.ModelState["Imagenes"].Errors[0].ErrorMessage
                                    </span>
                                }

                                <div class="preview-container bg-light rounded border p-2">
                                    <img id="previewImage"
                                         class="img-fluid rounded d-none"
                                         style="max-height:180px;" />
                                    <p id="previewPlaceholder" class="text-muted small mb-0 py-4">
                                        No hay imagen seleccionada
                                    </p>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- BOTONES -->
                    <div class="col-12 mt-4 border-top pt-4">
                        <div class="d-flex gap-3 justify-content-end">
                            <a asp-action="Index" class="btn btn-light px-4 border">
                                <i class="bi bi-arrow-left me-1"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-primary px-5 shadow">
                                <i class="bi bi-cloud-arrow-up me-1"></i> Publicar Objeto
                            </button>
                        </div>
                    </div>

                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>
        const input = document.getElementById('imageFiles');
        const preview = document.getElementById('previewImage');
        const placeholder = document.getElementById('previewPlaceholder');

        input?.addEventListener('change', () => {
            const file = input.files && input.files[0];
            if (!file) {
                preview.classList.add('d-none');
                placeholder.classList.remove('d-none');
                preview.src = '';
                return;
            }
            preview.src = URL.createObjectURL(file);
            preview.classList.remove('d-none');
            placeholder.classList.add('d-none');
        });

        $(document).ready(function () {
            if ($.fn.multiselect) {
                $('#selectedCategorias').multiselect({
                    buttonClass: 'form-select text-start shadow-none',
                    buttonWidth: '100%',
                    templates: {
                        button: '<button type="button" class="multiselect dropdown-toggle" data-bs-toggle="dropdown"><span class="multiselect-selected-text"></span></button>',
                    },
                    includeSelectAllOption: true,
                    selectAllText: ' Seleccionar todas',
                    allSelectedText: 'Todas seleccionadas',
                    nonSelectedText: 'Selecciona las categorías',
                    nSelectedText: ' seleccionadas'
                });
            }
        });
    </script>
}