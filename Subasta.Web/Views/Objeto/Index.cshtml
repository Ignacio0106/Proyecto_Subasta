@model IEnumerable<Subasta.Aplication.DTOs.ObjetoDTO>

@{
    ViewData["Title"] = "Listado de Objetos";
    var total = Model?.Count() ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-0">Listado de Objetos</h1>
        <p class="text-muted mb-0">Total de objetos: <strong>@total</strong></p>
    </div>

    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="bi bi-plus-circle me-1"></i>
        Nuevo Objeto
    </a>
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info d-flex align-items-center" role="alert">
        <i class="bi bi-info-circle me-2"></i>
        <div>No hay objetos registrados en este momento.</div>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <div class="bg-light rounded-top d-flex justify-content-center align-items-center"
                         style="height: 220px; overflow: hidden;">

                        @if (item.ImagenPrincipal != null && item.ImagenPrincipal.Length > 0)
                        {
                            <img class="img-fluid"
                                 style="max-height: 100%; max-width: 100%; object-fit: contain;"
                                 src="data:image/jpeg;base64,@Convert.ToBase64String(item.ImagenPrincipal)"
                                 alt="Imagen de @item.Nombre"
                                 loading="lazy" />
                        }
                        else
                        {
                            <div class="d-flex justify-content-center align-items-center h-100 text-muted">
                                <i class="bi bi-image fs-1"></i>
                                <span class="small ms-2">Sin imagen</span>
                            </div>
                        }
                    </div>
                    <div class="card-body">
                        <h2 class="h6 fw-semibold mb-1 text-truncate" title="@item.Nombre">
                            @item.Nombre
                        </h2>

                        <p class="small mb-2">
                            <strong>Categorías:</strong><br />
                            @if (item.Categorias.Any())
                            {
                                foreach (var categoria in item.Categorias)
                                {
                                    <span class="badge border-1 border-info text-primary bg-light px-2 py-2 rounded-pill shadow-sm m-1">@categoria</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">Sin categoría</span>
                            }
                        </p>

                        <p class="small mb-0">
                            <strong>Condición:</strong>
                                @item.Condicion
                        </p>
                    </div>

                    <!-- Acciones -->
                    <div class="card-footer bg-body border-0 pt-0 pb-3">
                        <div class="d-flex w-100 gap-2">

                            <!-- Ver detalle -->
                            <a asp-controller="Objeto"
                               asp-action="Details"
                               asp-route-id="@item.IdObjeto"
                               class="btn btn-primary flex-fill d-flex align-items-center justify-content-center">
                                <i class="bi bi-eye"></i>
                            </a>

                            @if (item.HistorialSubastas == null ||
                           !item.HistorialSubastas.Any(s => s.EstadoSubasta == "Activa"))
                            {
                                <!-- Editar -->
                                <a asp-controller="Objeto"
                                   asp-action="Edit"
                                   asp-route-id="@item.IdObjeto"
                                   class="btn btn-warning flex-fill d-flex align-items-center justify-content-center">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                            }

                            <!-- Switch -->
                            <form asp-controller="Objeto" asp-action="ToggleEstado" method="post" class="flex-fill d-flex justify-content-center align-items-center">
                                <input type="hidden" name="id" value="@item.IdObjeto" />

                                <label class="switch m-0">
                                    <input type="checkbox"
                                           onchange="confirmarCambio(this)"
                                    @(item.Estado == "Activo" ? "checked" : "")>
                                    <span class="slider"></span>
                                </label>
                            </form>

                        </div>
                    </div>
                 </div>
            </div>
        }
    </div>
}

@section Scripts {

    @if (TempData["Mensaje"] != null)
    {
        var mensaje = TempData["Mensaje"].ToString();

        <script>
            Swal.fire({
                icon: 'success',
                title: '@mensaje',
                showConfirmButton: false,
                timer: 2000
            });
        </script>
    }

    <style>
        .card-footer .btn {
            border-radius: 10px;
            height: 45px;
            font-size: 18px;
        }
        .card:hover {
            transform: translateY(-3px);
            transition: transform 0.18s ease;
        }

        .object-fit-cover {
            object-fit: cover;
        }

        /* 🔥 SWITCH BONITO */
        .switch {
            position: relative;
            display: inline-block;
            width: 55px;
            height: 30px;
        }

            .switch input {
                opacity: 0;
                width: 0;
                height: 0;
            }

        .slider {
            position: absolute;
            cursor: pointer;
            background-color: #ccc;
            border-radius: 34px;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            transition: 0.4s;
        }

            .slider:before {
                position: absolute;
                content: "";
                height: 22px;
                width: 22px;
                left: 4px;
                bottom: 4px;
                background-color: white;
                border-radius: 50%;
                transition: 0.4s;
            }

        input:checked + .slider {
            background-color: #198754; /* verde */
        }

            input:checked + .slider:before {
                transform: translateX(24px);
            }
    </style>

    <script>
        function confirmarCambio(elemento) {

            let activar = elemento.checked;

            Swal.fire({
                title: activar ? "¿Activar objeto?" : "¿Desactivar objeto?",
                text: activar
                    ? "El objeto estará disponible."
                    : "El objeto dejará de estar disponible.",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: "Sí, continuar",
                cancelButtonText: "Cancelar"
            }).then((result) => {

                if (result.isConfirmed) {
                    elemento.form.submit();
                } else {
                    elemento.checked = !elemento.checked;
                }
            });
        }
    </script>


}