@model Subasta.Aplication.DTOs.UsuarioDTO

@{
    ViewData["Title"] = "Detalle de Usuario";

    var inicial = !string.IsNullOrEmpty(Model.NombreCompleto)
        ? Model.NombreCompleto.Trim()[0].ToString().ToUpper()
        : "U";

    var rolClass = Model.Rol switch
    {
        "Administrador" => "bg-dark",
        "Vendedor" => "bg-primary",
        "Comprador" => "bg-secondary",
        _ => "bg-light text-dark border"
    };

    var estadoActivo = Model.Estado == "Activo";
}

<div class="container mt-5">

    <div class="card shadow-sm border-0 rounded-4">

        <div class="card-body border-bottom">

            <div class="d-flex align-items-center">

                <!-- Avatar -->
                <div class="rounded-circle bg-light border d-flex align-items-center justify-content-center fw-bold text-primary me-4"
                     style="width: 70px; height: 70px; font-size: 28px;">
                    @inicial
                </div>

                <div>
                    <h3 class="fw-bold mb-1">@Model.NombreCompleto</h3>

                    <span class="badge @rolClass me-2 px-3 py-2">
                        @Model.Rol
                    </span>

                    <span class="badge rounded-pill px-3 py-2 @(estadoActivo ? "bg-success" : "bg-danger")">
                        <i class="bi @(estadoActivo ? "bi-check-circle-fill" : "bi-x-circle-fill") me-1"></i>
                        @Model.Estado
                    </span>
                </div>

            </div>

        </div>

        <!-- Información -->
        <div class="card-body">

            <h5 class="fw-semibold mb-3">Información básica</h5>

            <div class="row mb-3">
                <div class="col-md-4 text-muted">Fecha de registro</div>
                <div class="col-md-8 fw-semibold">
                    @Model.FechaRegistro.ToString("dd MMMM yyyy")
                </div>
            </div>

        </div>

        <!-- Historial -->
        @if (!(Model.Rol == "Administrador")){
        <div class="card-body bg-light rounded-bottom-4">

            <h5 class="fw-semibold mb-4">Historial asociado</h5>

            <div class="row text-center">

                @if (Model.CantidadSubastas.HasValue)
                {
                    <div class="col-md-6 mb-3">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <i class="bi bi-hammer display-6 text-primary"></i>
                                <h4 class="fw-bold mt-2">@Model.CantidadSubastas</h4>
                                <p class="text-muted mb-0">Subastas creadas</p>
                            </div>
                        </div>
                    </div>
                }

                @if (Model.CantidadPujas.HasValue)
                {
                    <div class="col-md-6 mb-3">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <i class="bi bi-cash-coin display-6 text-success"></i>
                                <h4 class="fw-bold mt-2">@Model.CantidadPujas</h4>
                                <p class="text-muted mb-0">Pujas realizadas</p>
                            </div>
                        </div>
                    </div>
                }

            </div>

        </div>
        }
        <!-- Footer -->
        <div class="card-footer bg-white text-end border-0">

            <a asp-action="Edit"
               asp-route-id="@Model.IdUsuario"
               class="btn btn-primary me-2">
                <i class="bi bi-pencil-square me-1"></i>
                Editar
            </a>

            <a asp-action="Index"
               class="btn btn-outline-dark">
                <i class="bi bi-arrow-left me-1"></i>
                Volver al listado
            </a>

        </div>

    </div>

</div>