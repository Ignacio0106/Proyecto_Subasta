@model Subasta.Aplication.DTOs.UsuarioDTO

@{
    ViewData["Title"] = "Editar Perfil";
}

<div class="container mt-5">

    <h3 class="fw-bold mb-3">Editar Perfil</h3>
    <p class="text-muted mb-4">Solo puedes modificar tu nombre y correo electrónico.</p>

    <form asp-action="Edit">
        <input type="hidden" asp-for="IdUsuario" />

        <div class="row g-4">

            <!-- 🔹 IZQUIERDA (NO EDITABLE - SIMPLE) -->
            <div class="col-md-5">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">

                        <h5 class="fw-semibold mb-3 text-muted">Información</h5>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Rol</label>
                            <input class="form-control" value="@Model.Rol" disabled />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Estado</label>
                            <input class="form-control" value="@Model.Estado" disabled />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Fecha de registro</label>
                            <input class="form-control"
                                   value="@Model.FechaRegistro.ToString("dd/MM/yyyy")"
                                   disabled />
                        </div>

                    </div>
                </div>
            </div>

            <!-- 🔹 DERECHA (EDITABLE) -->
            <div class="col-md-7">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">

                        <h5 class="fw-semibold mb-3">Datos editables</h5>

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="NombreCompleto" class="form-label fw-semibold"></label>
                            <input asp-for="NombreCompleto" class="form-control" />
                            <span asp-validation-for="NombreCompleto" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CorreoElectronico" class="form-label fw-semibold"></label>
                            <input asp-for="CorreoElectronico" type="email" class="form-control" />
                            <span asp-validation-for="CorreoElectronico" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                Cancelar
                            </a>

                            <button type="submit" class="btn btn-primary">
                                Guardar cambios
                            </button>
                        </div>

                    </div>
                </div>
            </div>

        </div>

    </form>

</div>