@model IEnumerable<Subasta.Aplication.DTOs.UsuarioDTO>

@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Listado de Usuarios</h2>
        </div>

        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-circle me-1"></i>
            Nuevo Usuario
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body">

            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">

                    <thead class="table-dark">
                        <tr>
                            <th>Nombre Completo</th>
                            <th class="text-center">Rol</th>
                            <th class="text-center">Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle">

                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center fw-semibold me-3"
                                             style="width:42px; height:42px; font-size:0.9rem;">
                                            @(item.NombreCompleto?.Substring(0, 1).ToUpper() ?? "")
                                        </div>

                                        <div class="fw-semibold">@item.NombreCompleto</div>
                                    </div>
                                </td>
                                <td class="text-center align-middle ">
                                    @{
                                        var rolClass = item.Rol switch
                                        {
                                            "Administrador" => "bg-dark text-white",
                                            "Vendedor" => "bg-primary text-white",
                                            _ => "bg-body-tertiary text-black"
                                        };
                                    }

                                    <span class="badge @rolClass rounded-pill px-3 py-2 fw-semibold">
                                        @item.Rol
                                    </span>
                                </td>
                                <td class="text-center">
                                    @if (item.Estado == "Activo")
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill">
                                            <i class="bi bi-check-circle-fill me-1"></i> Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill">
                                            <i class="bi bi-x-circle-fill me-1"></i> Inactivo
                                        </span>
                                    }
                                </td>

                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-3 fs-5">
                                        <a asp-action="Edit"
                                           asp-route-id="@item.IdUsuario"
                                           class="btn btn-outline-dark px-2 py-1">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>

                                        <a asp-action="Details"
                                           asp-route-id="@item.IdUsuario"
                                           class="btn btn-outline-dark px-2 py-1">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <a asp-action="Delete"
                                           asp-route-id="@item.IdUsuario"
                                           class="btn btn-outline-danger px-2 py-1">
                                            <i class="bi bi-trash"></i>
                                        </a>

                                    </div>
                                </td>

                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>