@model IEnumerable<Subasta.Aplication.DTOs.UsuarioDTO>

@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Listado de Usuarios</h2>
        </div>

        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-circle me-1"></i>
            Nuevo Usuario
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body">

            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">

                    <thead class="table-dark">
                        <tr>
                            <th>Nombre Completo</th>
                            <th class="text-center">Rol</th>
                            <th class="text-center">Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle">

                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center fw-semibold me-3"
                                             style="width:42px; height:42px; font-size:0.9rem;">
                                            @(item.NombreCompleto?.Substring(0, 1).ToUpper() ?? "")
                                        </div>

                                        <div class="fw-semibold">@item.NombreCompleto</div>
                                    </div>
                                </td>
                                <td class="text-center align-middle ">
                                    @{
                                        var rolClass = item.Rol switch
                                        {
                                            "Administrador" => "bg-dark text-white",
                                            "Vendedor" => "bg-primary text-white",
                                            _ => "bg-body-tertiary text-black"
                                        };
                                    }

                                    <span class="badge @rolClass rounded-pill px-3 py-2 fw-semibold">
                                        @item.Rol
                                    </span>
                                </td>
                                <td class="text-center">
                                    @if (item.Estado == "Activo")
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill">
                                            <i class="bi bi-check-circle-fill me-1"></i> Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill">
                                            <i class="bi bi-x-circle-fill me-1"></i> Inactivo
                                        </span>
                                    }
                                </td>

                                <td class="text-center">
                                    <div class="d-flex w-100 gap-2">

                                        <!-- Ver detalle -->
                                        <a asp-action="Details"
                                           asp-route-id="@item.IdUsuario"
                                           class="btn btn-primary btn-sm flex-fill d-flex align-items-center justify-content-center">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <!-- Editar -->
                                        <a asp-action="Edit"
                                           asp-route-id="@item.IdUsuario"
                                           class="btn btn-warning btn-sm flex-fill d-flex align-items-center justify-content-center">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>

                                       
                                        <!-- Switch de Estado -->
                                        <form asp-action="ToggleEstado" method="post" class="flex-fill d-flex justify-content-center align-items-center m-0">
                                            <input type="hidden" name="id" value="@item.IdUsuario" />
                                            <label class="switch m-0">
                                                <input type="checkbox"
                                                       onchange="confirmarCambio(this)"
                                                @(item.Estado == "Activo" ? "checked" : "")>
                                                <span class="slider"></span>
                                            </label>
                                        </form>

                                    </div>
                                </td>

                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>
@section Scripts{
    @if (TempData["Mensaje"] != null)
    {
        var mensaje = TempData["Mensaje"].ToString();

        <script>
            Swal.fire({
                icon: 'success',
                title: '@mensaje',
                showConfirmButton: false,
                timer: 2000
            });
        </script>
    }
    <style>
.switch {
    position: relative;
    display: inline-block;
    width: 50px;
    height: 26px;
}

.switch input {
    opacity: 0;
    width: 0;
    height: 0;
}

.slider {
    position: absolute;
    cursor: pointer;
    background-color: #ccc;
    border-radius: 30px;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    transition: 0.4s;
}

.slider:before {
    position: absolute;
    content: "";
    height: 20px;
    width: 20px;
    left: 3px;
    bottom: 3px;
    background-color: white;
    border-radius: 50%;
    transition: 0.4s;
}

input:checked + .slider {
    background-color: #198754;
}

input:checked + .slider:before {
    transform: translateX(22px);
}
</style>
<script>
    function confirmarCambio(elemento) {

        let activar = elemento.checked;

        Swal.fire({
            title: activar ? "¿Activar usuario?" : "¿Desactivar usuario?",
            text: activar
                ? "El usuario podrá usar el sistema."
                : "El usuario será bloqueado.",
            icon: "warning",
            showCancelButton: true,
            confirmButtonText: "Sí",
            cancelButtonText: "Cancelar"
        }).then((result) => {

            if (result.isConfirmed) {
                elemento.form.submit();
            } else {
                elemento.checked = !elemento.checked;
            }
        });
    }
</script>
}