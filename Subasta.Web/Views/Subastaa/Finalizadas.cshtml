@model IEnumerable<Subasta.Aplication.DTOs.SubastaDTO>

@{
    ViewData["Title"] = "Finalizadas";
}

<h1 class="mb-4">Subastas Finalizadas</h1>

<div class="container">
    <div class="row g-4">

        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card h-100 shadow-sm">

                    <div class="bg-light rounded-top d-flex justify-content-center align-items-center"
                         style="height: 220px; overflow: hidden;">

                        @if (item.ImagenPrincipal != null && item.ImagenPrincipal.Length > 0)
                        {
                            <img class="img-fluid"
                                 style="max-height: 100%; max-width: 100%; object-fit: contain;"
                                 src="data:image/jpeg;base64,@Convert.ToBase64String(item.ImagenPrincipal)"
                                 alt="Imagen de @item.ImagenPrincipal"
                                 loading="lazy" />
                        }
                        else
                        {
                            <div class="d-flex justify-content-center align-items-center h-100 text-muted">
                                <i class="bi bi-image fs-1"></i>
                                <span class="small ms-2">Sin imagen</span>
                            </div>
                        }
                    </div>

                    <div class="card-body d-flex flex-column">

                        <h5 class="card-title">@item.Objeto</h5>

                        <p class="card-text mb-1">
                            <strong>Precio Base:</strong> ₡@item.PrecioBase
                        </p>

                        <p class="card-text mb-1">
                            <strong>Pujas:</strong> @item.CantidadPujas
                        </p>

                        <p class="card-text text-danger">
                            <strong>Cerró el:</strong> @item.FechaHoraCierre.ToString("f")
                        </p>

                        <div class="mt-auto">
                            <a asp-action="Details" asp-route-id="@item.IdSubasta"
                               class="btn btn-primary w-100">
                                Ver Detalles
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        }

    </div>
</div>